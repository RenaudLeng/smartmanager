generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL", "file:./dev.db")
}

model Tenant {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  phone             String?
  address           String?
  businessType      String   // bar, restaurant, grocery, hair_salon, etc.
  currency          String   @default("XAF")
  status            String   @default("active") // active, inactive, suspended
  features          String?  // Configuration dynamique JSON en string
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  users             User[]
  products          Product[]
  categories        Category[]
  sales             Sale[]
  expenses          Expense[]
  staff             Staff[]
  clients           Client[]
  suppliers         Supplier[]
  debts             Debt[]
  inventoryLogs     InventoryLog[]
  subscriptions     Subscription[]
  dashboardConfigs   DashboardConfig[]
  auditLogs         AuditLog[]

  @@map("tenants")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String
  role              String   // super_admin, admin, manager, cashier, seller
  tenantId          String?
  isActive          Boolean  @default(true)
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  sales             Sale[]
  expenses          Expense[]
  auditLogs         AuditLog[]

  @@unique([email, tenantId])
  @@map("users")
}

model Category {
  id                String   @id @default(cuid())
  name              String
  description       String?
  tenantId          String
  businessType      String?  // for pre-configured categories
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  products          Product[]

  @@unique([name, tenantId])
  @@map("categories")
}

model Product {
  id                String   @id @default(cuid())
  name              String
  description       String?
  barcode           String?  @unique
  image             String?
  purchasePrice     Float    @default(0)
  sellingPrice      Float
  margin            Float?
  profitability     Float?   // Rentabilité en pourcentage
  quantity          Float    @default(0)
  minStock          Float    @default(0)
  categoryId        String
  supplierId        String?
  expirationDate    DateTime?
  tenantId          String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  category          Category @relation(fields: [categoryId], references: [id])
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  saleItems         SaleItem[]
  inventoryLogs     InventoryLog[]

  @@unique([name, tenantId])
  @@map("products")
}

model Supplier {
  id                String   @id @default(cuid())
  name              String
  phone             String?
  email             String?
  address           String?
  tenantId          String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  products          Product[]

  @@unique([name, tenantId])
  @@map("suppliers")
}

model Sale {
  id                String   @id @default(cuid())
  totalAmount       Float
  discountAmount    Float    @default(0)
  finalAmount       Float
  paymentType       String   // cash, mobile_money, mixed
  paymentStatus     String   @default("paid") // paid, pending, partial
  clientId          String?
  userId            String
  tenantId          String
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  client            Client?  @relation(fields: [clientId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             SaleItem[]

  @@map("sales")
}

model SaleItem {
  id                String   @id @default(cuid())
  saleId            String
  productId         String
  quantity          Float
  unitPrice         Float
  totalPrice        Float
  createdAt         DateTime @default(now())

  // Relations
  sale              Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Client {
  id                String   @id @default(cuid())
  name              String
  phone             String?
  email             String?
  address           String?
  tenantId          String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  sales             Sale[]
  debts             Debt[]

  @@unique([name, tenantId])
  @@map("clients")
}

model Debt {
  id                String   @id @default(cuid())
  clientId          String
  amount            Float
  paidAmount        Float    @default(0)
  remainingAmount   Float
  status            String   @default("pending") // pending, paid, partial
  dueDate           DateTime?
  tenantId          String
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  client            Client   @relation(fields: [clientId], references: [id])

  @@map("debts")
}

model Expense {
  id                String   @id @default(cuid())
  category          String   // electricity, water, rent, salaries, taxes, transport, purchases
  amount            Float
  description       String?
  receiptNumber     String?
  userId            String
  tenantId          String
  date              DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Staff {
  id                String   @id @default(cuid())
  name              String
  role              String   // manager, cashier, seller, etc.
  phone             String?
  email             String?
  salary            Float?
  hireDate          DateTime?
  isActive          Boolean  @default(true)
  tenantId          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId])
  @@map("staff")
}

model InventoryLog {
  id                String   @id @default(cuid())
  productId         String
  type              String   // in, out, adjustment
  quantity          Float
  reason            String?
  userId            String?
  tenantId          String
  createdAt         DateTime @default(now())

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  product           Product  @relation(fields: [productId], references: [id])

  @@map("inventory_logs")
}

model Subscription {
  id                String   @id @default(cuid())
  tenantId          String
  plan              String   // basic, premium, enterprise
  price             Float
  startDate         DateTime
  endDate           DateTime
  status            String   // active, expired, cancelled
  features          String   // JSON string of features
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model Notification {
  id                String   @id @default(cuid())
  title             String
  message           String
  type              String   // low_stock, unpaid_invoice, customer_debt, expired_subscription
  userId            String?
  tenantId          String
  isRead            Boolean  @default(false)
  data              String?  // Additional notification data as JSON string
  createdAt         DateTime @default(now())

  @@map("notifications")
}

model DashboardConfig {
  id                String   @id @default(cuid())
  dailyObjective    Int      @default(100000)
  dailyExpenseLimit Int      @default(50000)
  minProfitMargin   Float    @default(15)
  lowStockThreshold Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenantId          String

  // Relations
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId])
  @@map("dashboard_configs")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // create, update, delete, login, logout, suspend, etc.
  entity      String   // user, tenant, product, sale, etc.
  entityId    String
  userId      String
  tenantId    String?
  ipAddress   String?
  userAgent   String?
  details     String?  // Additional context as JSON string
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  // Relations
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}
