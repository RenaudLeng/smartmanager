{
  "name": "smartmanager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:install": "playwright install",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --project=chromium tests/e2e/smoke.spec.ts",
    "test:e2e": "playwright test",
    "test:unit": "echo 'Tests unitaires à implémenter'",
    "test:load": "echo 'Tests de charge à implémenter'",
    "test:production": "TEST_BASE_URL=https://smartmanager.com bash scripts/test.sh",
    "deploy": "bash scripts/deploy.sh",
    "analyze": "ANALYZE=true npm run build",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "node scripts/seed.js",
    "backup": "bash scripts/backup.sh",
    "vercel-build": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps && DATABASE_URL=\"file:./dev.db\" npx prisma generate && DATABASE_URL=\"file:./dev.db\" npx prisma migrate deploy && npm run build"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@zxing/library": "^0.21.3",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.15",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "eslint": "^8.57.1"
  }
}
